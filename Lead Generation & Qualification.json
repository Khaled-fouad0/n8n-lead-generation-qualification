    {
      "parameters": {
        "jsCode": "const lead = $input.first().json.body;\nconst required = ['name', 'email', 'message'];\nconst missing = required.filter(field => !lead[field]);\n\nif (missing.length > 0) {\n  throw new Error(`Missing required fields: ${missing.join(', ')}`);\n}\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (!emailRegex.test(lead.email)) {\n  throw new Error(`Invalid email: ${lead.email}`);\n}\nreturn [{\n  json: {\n    lead_id: `LEAD-${Date.now()}`,\n    name: lead.name,\n    email: lead.email,\n    company: lead.company || 'Unknown',\n    role: lead.role || 'Unknown',\n    employees: lead.employees || 0,\n    message: lead.message,\n    source: lead.source || 'Website',\n    received_at: new Date().toISOString(),\n    status: 'new'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "83b3606a-b750-4f32-93a5-230a291e2def",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "groqApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.3,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a lead qualification specialist. Return ONLY valid JSON, no extra text, no markdown, no backticks.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Qualify this lead:\\n\\nName: {{ $json.name }}\\nCompany: {{ $json.company }}\\nRole: {{ $json.role }}\\nEmployees: {{ $json.employees }}\\nMessage: {{ $json.message }}\\nSource: {{ $json.source }}\\n\\nCustomer History:\\n- Previous visits: {{ $json.previous_visits }}\\n- {{ $json.history_summary }}\\n\\n{{ $json.has_history ? 'This is a RETURNING customer - be more personal and reference their history' : 'This is a NEW customer' }}\\n\\nReturn ONLY this JSON:\\n{\\n  \\\"score\\\": 40,\\n  \\\"tier\\\": \\\"WARM\\\",\\n  \\\"reason\\\": \\\"brief reason\\\",\\n  \\\"pain_points\\\": [\\\"point1\\\", \\\"point2\\\"],\\n  \\\"recommended_action\\\": \\\"what to do next\\\",\\n  \\\"personalized_email_intro\\\": \\\"Dear Khaled, ...\\\"\\n}\\n\\nTiers: HOT (80-100) / WARM (50-79) / COLD (0-49)\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1248,
        0
      ],
      "id": "58c95de1-f129-4989-9fb5-417051dd624d",
      "name": "HTTP Request",
      "retryOnFail": true,
      "waitBetweenTries": 2000,
      "credentials": {
        "groqApi": {
          "id": "HPqV8Vvjvg1NGKa5",
          "name": "Groq account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst aiContent = response.choices[0].message.content;\nconst lead = $('Code in JavaScript').first().json;\n\nlet qualification;\ntry {\n  qualification = JSON.parse(aiContent);\n} catch (e) {\n  throw new Error('AI did not return valid JSON: ' + aiContent);\n}\n\nreturn [{\n  json: {\n    ...lead,\n    score: qualification.score,\n    tier: qualification.tier,\n    reason: qualification.reason,\n    pain_points: qualification.pain_points,\n    recommended_action: qualification.recommended_action,\n    personalized_email_intro: qualification.personalized_email_intro\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
