    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst lead = $('Code in JavaScript').first().json;\n\nconst hasHistory = items.length > 0 && items[0].json['Lead ID'];\n\nlet history_summary, previous_visits, has_history;\n\nif (hasHistory) {\n  const lastThree = items.slice(-3);\n  history_summary = lastThree.map((row, i) => \n    `Visit ${i+1}: ${String(row.json['Action']).replace(/[\"\\n\\r]/g, '')} | Tier: ${row.json['Tier']}`\n  ).join(' /// ');\n  previous_visits = items.length;\n  has_history = true;\n} else {\n  history_summary = 'New customer - no previous history';\n  previous_visits = 0;\n  has_history = false;\n}\nreturn [{\n  json: {\n    ...lead,\n    has_history,\n    previous_visits,\n    history_summary\n  }\n}];"
      },
